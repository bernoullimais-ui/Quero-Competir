# =============================================================================
# QUERO COMPETIR — Variáveis de Ambiente
# =============================================================================
# Copie este arquivo para .env.local e preencha com seus valores reais.
# NUNCA faça commit de .env ou .env.local (já protegidos pelo .gitignore).
# Para deploy na Vercel, configure cada variável no painel:
#   Settings → Environment Variables
# =============================================================================

# -----------------------------------------------------------------------------
# SUPABASE — Banco de Dados
# Obtenha em: https://supabase.com/dashboard/project/_/settings/api
# -----------------------------------------------------------------------------

# URL do projeto Supabase (ex: https://abcdefgh.supabase.co)
SUPABASE_URL="https://seu-projeto.supabase.co"

# Chave anônima — usada pelo backend para operações públicas
# Escopo na Vercel: Production, Preview, Development
SUPABASE_ANON_KEY="eyJhbGci..."

# Chave de service role — acesso total ao banco (APENAS BACKEND)
# ⚠️  NUNCA exponha esta chave no frontend ou em logs públicos
# Escopo na Vercel: Production (somente — nunca Preview/Development público)
SUPABASE_SERVICE_ROLE_KEY="eyJhbGci..."

# Variáveis prefixadas VITE_ são injetadas no bundle do frontend em build time.
# Devem ter os MESMOS valores de SUPABASE_URL e SUPABASE_ANON_KEY acima.
VITE_SUPABASE_URL="https://seu-projeto.supabase.co"
VITE_SUPABASE_ANON_KEY="eyJhbGci..."

# -----------------------------------------------------------------------------
# AUTENTICAÇÃO
# -----------------------------------------------------------------------------

# Segredo JWT — usado para assinar e verificar tokens de sessão.
# Gere um valor seguro: openssl rand -base64 48
# ⚠️  Use um valor diferente em produção. Mínimo 32 caracteres.
# Escopo na Vercel: Production (somente)
JWT_SECRET="troque-por-uma-string-aleatoria-longa-e-secreta"

# -----------------------------------------------------------------------------
# APLICAÇÃO
# -----------------------------------------------------------------------------

# URL pública onde o app está hospedado — usada para CORS em produção.
# Exemplo Vercel: https://quero-competir.vercel.app
# Exemplo domínio próprio: https://app.querocompetir.com.br
APP_URL="https://seu-dominio.vercel.app"

# Porta local do servidor Express (ignorada na Vercel)
PORT=3000

# -----------------------------------------------------------------------------
# PAGAR.ME — Gateway de Pagamento (opcional)
# Obtenha em: https://dashboard.pagar.me/
# Deixe em branco para desabilitar o módulo de pagamentos.
# -----------------------------------------------------------------------------

# Chave pública do Pagar.me (exposta ao frontend via API — não é secret)
PAGARME_PUBLIC_KEY="pk_..."

# Chave secreta do Pagar.me (APENAS BACKEND)
# ⚠️  NUNCA exponha esta chave no frontend
# Escopo na Vercel: Production (somente)
PAGARME_SECRET_KEY="sk_..."

# -----------------------------------------------------------------------------
# GEMINI AI — Integração IA (opcional)
# Obtenha em: https://aistudio.google.com/apikey
# -----------------------------------------------------------------------------
GEMINI_API_KEY="AIza..."
